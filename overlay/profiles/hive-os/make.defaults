# HIVE OS profile defaults
# Gentoo base profile customization for HIVE ecosystem

# Security-focused flags
SECURITY_FLAGS="-fPIE -fstack-protector-all -Wl,-z,relro,-z,now"
CFLAGS="${CFLAGS} ${SECURITY_FLAGS}"
CXXFLAGS="${CXXFLAGS} ${SECURITY_FLAGS}"
LDFLAGS="${LDFLAGS} -Wl,-z,relro,-z,now"

# HIVE-specific USE flags
USE_HIVE="hive pam audit systemd"
USE="${USE} ${USE_HIVE}"

# Optimization
CFLAGS="-O2 -march=native"
CXXFLAGS="${CFLAGS}"

# PAM enabled
USE_PAM="true"

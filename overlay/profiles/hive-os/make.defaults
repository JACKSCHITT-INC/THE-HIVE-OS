# HIVE OS Profile make.defaults - 2026 ARCHITECT BUILD
# Only Authorized Agents

ARCH="amd64"
CHOST="x86_64-pc-linux-gnu"

USE="${USE} hive hive-personality hive-collective zorg pam audit"

CFLAGS="-O2 -pipe -fomit-frame-pointer -march=native"
CXXFLAGS="${CFLAGS}"

HIVE_FEATURES="personality collective audit update sovereign"
HIVE_DEFAULT_TYPE="GENTOO"
HIVE_COLLECTIVE_URL="https://collective.hive-os.org/v1"

MAKEOPTS="-j$(nproc)"
FEATURES="splitdebug parallel-fetch"
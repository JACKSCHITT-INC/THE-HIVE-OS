# HIVE PAM sshd configuration
# Zero-trust SSH authentication with personality verification

auth [success=ok default=bad] pam_unix.so nullok
auth [success=ok default=bad] pam_hive.so
auth requisite pam_deny.so
auth required pam_permit.so

account required pam_unix.so
account required pam_hive.so
account required pam_permit.so

password [success=ok default=unstable] pam_unix.so obscure sha512 rounds=5000
password required pam_hive.so
password required pam_permit.so

session optional pam_systemd.so
session required pam_limits.so
session required pam_unix.so
session required pam_hive.so
session optional pam_permit.so

# HIVE OS .gitignore - Clean & Sovereign

# Build artifacts
*.o
*.so
*.a
*.so.*
hive-init
hive-shell
hive-test
pam_hive.so
libhive.so

# Generated / Temp
*.tmp
*.log
*.conf.bak
*.swp
*.swo

# Runtime data
/tmp/
*/.tmp_versions/
*.mod*
modules.order
Module.symvers

# Sensitive / Personal
*.key
*.pem
*.secret
/etc/hive/personality/*.conf
/var/log/hive/*
/var/lib/hive/*

# Dist / Large files
*.tar.gz
*.tar.xz
distfiles/

# Editor / OS junk
.vscode/
.idea/
.DS_Store
Thumbs.db

# Keep source
!*.h
!*.c
!Makefile
!*.ebuild
!*.eclass
!README.md
!LICENSE
!INSTALL.md
